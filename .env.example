# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# LLM API Configuration
# Choose one or both depending on your needs
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Management API (only needed for scripts/configure-supabase-auth.ts)
# Generate at: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx

# Production URL (used by the auth config script to set Supabase redirect URLs)
# PRODUCTION_URL=https://mbook.vercel.app
